{
  "DAMAGE_TOTAL": "@DAMAGE_SLASH + @DAMAGE_IMPACT + @DAMAGE_PUNCTURE + @DAMAGE_COLD + @DAMAGE_ELECTRICITY + @DAMAGE_HEAT + @DAMAGE_TOXIN + @DAMAGE_BLAST + @DAMAGE_CORROSIVE + @DAMAGE_GAS + @DAMAGE_MAGNETIC + @DAMAGE_RADIATION + @DAMAGE_VIRAL + @DAMAGE_TRUE + @DAMAGE_VOID + @DAMAGE_TAU",
  "DAMAGE_CRIT_CHANCE": "sum($$BASE_CRIT_CHANCE) * (1 + sum($$BOUNS_CRIT_CHANCE)",
  "DAMAGE_CRIT_MULTIPLIER": "sum($$BASE_CRIT_MULTIPLIER) * (1 + sum($$BOUNS_CRIT_MULTIPLIER))",
  "DAMAGE_STATUS_CHANCE": "sum($$BASE_PROC_CHANCE) * (1 + sum($$BOUNS_PROC_CHANCE))",

  "DAMAGE_IMPACT": "sum($$BASE_DAMAGE_IMPACT) * (1 + sum($$BOUNS_DAMAGE_IMPACT))",
  "DAMAGE_PUNCTURE": "sum($$BASE_DAMAGE_PUNCTURE) * (1 + sum($$BOUNS_DAMAGE_PUNCTURE))",
  "DAMAGE_SLASH": "sum($$BASE_DAMAGE_SLASH) * (1 + sum($$BOUNS_DAMAGE_SLASH))",

  "DAMAGE_COLD": "sum($$BASE_DAMAGE_COLD) * (1 + sum($$BOUNS_DAMAGE_COLD))",
  "DAMAGE_ELECTRICITY": "sum($$BASE_DAMAGE_ELECTRICITY) * (1 + sum($$BOUNS_DAMAGE_ELECTRICITY))",
  "DAMAGE_HEAT": "sum($$BASE_DAMAGE_HEAT) * (1 + sum($$BOUNS_DAMAGE_HEAT))",
  "DAMAGE_TOXIN": "sum($$BASE_DAMAGE_TOXIN) * (1 + sum($$BOUNS_DAMAGE_TOXIN))",

  "DAMAGE_BLAST": "sum($$BASE_DAMAGE_BLAST) * (1 + sum($$BOUNS_DAMAGE_BLAST))",
  "DAMAGE_CORROSIVE": "sum($$BASE_DAMAGE_CORROSIVE) * (1 + sum($$BOUNS_DAMAGE_CORROSIVE))",
  "DAMAGE_GAS": "sum($$BASE_DAMAGE_GAS) * (1 + sum($$BOUNS_DAMAGE_GAS))",
  "DAMAGE_MAGNETIC": "sum($$BASE_DAMAGE_MAGNETIC) * (1 + sum($$BOUNS_DAMAGE_MAGNETIC))",
  "DAMAGE_RADIATION": "sum($$BASE_DAMAGE_RADIATION) * (1 + sum($$BOUNS_DAMAGE_RADIATION))",
  "DAMAGE_VIRAL": "sum($$BASE_DAMAGE_VIRAL) * (1 + sum($$BOUNS_DAMAGE_VIRAL))",

  "DAMAGE_TRUE": "sum($$BASE_DAMAGE_TRUE) * (1 + sum($$BOUNS_DAMAGE_TRUE))",
  "DAMAGE_VOID": "sum($$BASE_DAMAGE_VOID) * (1 + sum($$BOUNS_DAMAGE_VOID))",
  "DAMAGE_TAU": "sum($$BASE_DAMAGE_TAU) * (1 + sum($$BOUNS_DAMAGE_TAU))"
}
